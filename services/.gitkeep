<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Service — Tbil Inn</title>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=Jost:wght@300;400;500&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="styles.css">
  <style>
    .lang-btn{font-family:'Jost',sans-serif;font-size:.6rem;font-weight:400;text-transform:uppercase;letter-spacing:.18em;background:none;border:none;cursor:pointer;color:rgba(255,255,255,.55);padding:4px 6px;transition:color .3s}
    .lang-btn.active,.lang-btn:hover{color:#fff}
    nav#desktop-nav.scrolled .lang-btn{color:var(--warm-gray)}
    nav#desktop-nav.scrolled .lang-btn.active,nav#desktop-nav.scrolled .lang-btn:hover{color:var(--accent)}
    #page-loader{position:fixed;inset:0;background:var(--ivory);z-index:9000;display:flex;align-items:center;justify-content:center;transition:opacity .5s}
    #page-loader.gone{opacity:0;pointer-events:none}
    .loader-logo{font-family:'Cormorant Garamond',serif;font-size:2rem;letter-spacing:.15em;color:var(--accent)}
    /* includes list */
    .includes-list{list-style:none;padding:0;margin-top:12px}
    .includes-list li{display:flex;align-items:center;gap:10px;padding:10px 0;border-bottom:1px solid var(--sand);font-size:.85rem;color:var(--warm-gray)}
    .includes-list li::before{content:'';display:block;width:4px;height:4px;background:var(--accent);border-radius:50%;flex-shrink:0}
  </style>
</head>
<body style="padding-bottom:70px">

  <div id="page-loader"><span class="loader-logo">Tbil Inn</span></div>

  <!-- DESKTOP NAV -->
  <nav id="desktop-nav">
    <a href="index.html" class="desktop-logo">Tbil Inn</a>
    <div class="desktop-links">
      <a href="index.html#rooms"    data-i18n="nav.rooms">Rooms</a>
      <a href="index.html#services" data-i18n="nav.services">Services</a>
      <a href="index.html#gallery"  data-i18n="nav.gallery">Gallery</a>
      <a href="index.html#contacts" data-i18n="nav.contacts">Contact</a>
    </div>
    <div style="display:flex;gap:6px" id="lang-sw-desktop"></div>
  </nav>

  <!-- MOBILE HEADER -->
  <header class="mobile-header" id="mobile-header">
    <a href="index.html" class="mobile-logo">Tbil Inn</a>
    <div style="display:flex;gap:12px;align-items:center">
      <div style="display:flex;gap:4px" id="lang-sw-mobile"></div>
      <button class="mobile-hamburger" onclick="toggleMobileMenu()">
        <span class="line-1"></span><span class="line-2"></span>
      </button>
    </div>
  </header>

  <!-- MOBILE MENU -->
  <div class="mobile-menu-overlay" id="mobile-menu-overlay">
    <div class="mobile-menu-top">
      <a href="index.html" style="font-family:'Cormorant Garamond',serif;font-size:1.2rem;letter-spacing:.1em;color:var(--charcoal);text-decoration:none">Tbil Inn</a>
      <button class="mobile-close" onclick="toggleMobileMenu()"><span class="material-symbols-outlined">close</span></button>
    </div>
    <nav class="mobile-menu-nav">
      <a href="index.html#rooms"    onclick="toggleMobileMenu()" data-i18n="nav.rooms">Rooms</a>
      <a href="index.html#services" onclick="toggleMobileMenu()" data-i18n="nav.services">Services</a>
      <a href="index.html#gallery"  onclick="toggleMobileMenu()" data-i18n="nav.gallery">Gallery</a>
      <a href="index.html#contacts" onclick="toggleMobileMenu()" data-i18n="nav.contacts">Contact</a>
    </nav>
  </div>

  <!-- HERO -->
  <section class="service-hero">
    <img id="hero-img" src="" alt="">
    <div class="overlay"></div>
    <div class="hero-content">
      <div class="breadcrumb">
        <a href="index.html" data-i18n="breadcrumb.home">Home</a>
        <span>/</span>
        <a href="index.html#services" data-i18n="breadcrumb.services">Services</a>
      </div>
      <h1 class="hero-title" id="svc-name"></h1>
      <span class="hero-subtitle" id="svc-short"></span>
    </div>
  </section>

  <!-- MAIN -->
  <main>
    <div class="page-container">

      <!-- Content column -->
      <div class="content-col">
        <div class="fade-in">
          <span class="section-label" data-i18n="svc.exp_label">The Experience</span>
          <h2 class="section-head" id="svc-title-2"></h2>
          <p class="text-body" id="svc-short-2"></p>
          <p class="text-detail" id="svc-desc"></p>
        </div>

        <!-- Gallery strip -->
        <div class="gallery-strip fade-in" id="gallery-strip"></div>

        <!-- Includes -->
        <div class="fade-in" id="includes-section">
          <span class="section-label" data-i18n="svc.includes_label">What's Included</span>
          <ul class="includes-list" id="includes-list"></ul>
        </div>
      </div>

      <!-- Sidebar -->
      <aside class="sidebar-col">
        <div class="sidebar-card fade-in">
          <h3 class="sidebar-title" id="svc-sidebar-name"></h3>

          <div class="info-row">
            <span class="material-symbols-outlined info-icon">payments</span>
            <div class="info-text">
              <span class="info-label" data-i18n="svc.price">Price</span>
              <span class="info-value" id="svc-price"></span>
            </div>
          </div>
          <div class="info-row">
            <span class="material-symbols-outlined info-icon">schedule</span>
            <div class="info-text">
              <span class="info-label" data-i18n="svc.duration">Duration</span>
              <span class="info-value" id="svc-duration"></span>
            </div>
          </div>
          <div class="info-row">
            <span class="material-symbols-outlined info-icon">event_available</span>
            <div class="info-text">
              <span class="info-label" data-i18n="svc.availability">Availability</span>
              <span class="info-value" id="svc-avail"></span>
            </div>
          </div>
          <div class="info-row">
            <span class="material-symbols-outlined info-icon">category</span>
            <div class="info-text">
              <span class="info-label" data-i18n="svc.category">Category</span>
              <span class="info-value" id="svc-cat"></span>
            </div>
          </div>

          <button class="btn-block" id="btn-book" data-i18n="svc.book_btn">Book This Service</button>
        </div>
      </aside>

    </div><!-- /page-container -->

    <!-- OTHER SERVICES -->
    <section class="other-services">
      <div class="other-services-header fade-in">
        <span class="section-label" data-i18n="other.label">Discover More</span>
        <h2 class="section-head" data-i18n="other.title">Other Services</h2>
        <div class="section-divider"></div>
      </div>
      <div class="other-services-grid" id="other-services-grid"></div>
    </section>

    <footer>
      <span class="footer-logo">Tbil Inn</span>
      <div class="footer-links">
        <a href="index.html#rooms"    data-i18n="nav.rooms">Rooms</a>
        <a href="index.html#services" data-i18n="nav.services">Services</a>
        <a href="index.html#gallery"  data-i18n="nav.gallery">Gallery</a>
        <a href="index.html#contacts" data-i18n="nav.contacts">Contact</a>
      </div>
      <span class="footer-copy">© 2025 Tbil Inn · Tbilisi, Georgia</span>
    </footer>
  </main>

  <!-- MOBILE STICKY BAR -->
  <div class="mobile-cta-bar">
    <span class="cta-text" id="mobile-avail">Open daily</span>
    <button class="cta-btn" id="cta-btn" data-i18n="svc.book_btn">Book Now</button>
  </div>

  <script type="module">
  import { getCurrentLang, setLang, t, getServiceById, getLiveServices, getContacts } from './main.js';

  const UI = {
    en:{ 'nav.rooms':'Rooms','nav.services':'Services','nav.gallery':'Gallery','nav.contacts':'Contact','breadcrumb.home':'Home','breadcrumb.services':'Services','svc.exp_label':'The Experience','svc.includes_label':"What's Included",'svc.price':'Price','svc.duration':'Duration','svc.availability':'Availability','svc.category':'Category','svc.book_btn':'Book This Service','other.label':'Discover More','other.title':'Other Services','explore':'Explore' },
    ru:{ 'nav.rooms':'Номера','nav.services':'Услуги','nav.gallery':'Галерея','nav.contacts':'Контакты','breadcrumb.home':'Главная','breadcrumb.services':'Услуги','svc.exp_label':'Об услуге','svc.includes_label':'Что включено','svc.price':'Цена','svc.duration':'Продолжительность','svc.availability':'Режим работы','svc.category':'Категория','svc.book_btn':'Забронировать','other.label':'Узнайте больше','other.title':'Другие услуги','explore':'Подробнее' },
    ka:{ 'nav.rooms':'ნომრები','nav.services':'სერვისები','nav.gallery':'გალერეა','nav.contacts':'კონტაქტი','breadcrumb.home':'მთავარი','breadcrumb.services':'სერვისები','svc.exp_label':'გამოცდილება','svc.includes_label':'რა შედის','svc.price':'ფასი','svc.duration':'ხანგრძლივობა','svc.availability':'ხელმისაწვდომობა','svc.category':'კატეგორია','svc.book_btn':'დაჯავშნა','other.label':'გაიგეთ მეტი','other.title':'სხვა სერვისები','explore':'დეტალები' }
  };

  const lang = getCurrentLang();
  const ui   = UI[lang] || UI.en;
  document.documentElement.lang = lang;
  document.querySelectorAll('[data-i18n]').forEach(el=>{ const v=ui[el.dataset.i18n]; if(v) el.textContent=v; });

  // Lang switchers
  ['lang-sw-desktop','lang-sw-mobile'].forEach(id=>{
    const el=document.getElementById(id); if(!el) return;
    ['en','ru','ka'].forEach(l=>{
      const b=document.createElement('button');
      b.className='lang-btn'+(l===lang?' active':'');
      b.textContent=l.toUpperCase(); b.onclick=()=>setLang(l); el.appendChild(b);
    });
  });

  // Scroll
  const dn=document.getElementById('desktop-nav'), mhdr=document.getElementById('mobile-header');
  window.addEventListener('scroll',()=>{ const s=window.scrollY>10; dn?.classList.toggle('scrolled',s); mhdr.classList.toggle('scrolled',s); });

  window.toggleMobileMenu=function(){
    const m=document.getElementById('mobile-menu-overlay');
    document.body.style.overflow=m.classList.toggle('open')?'hidden':'';
  };

  const obs=new IntersectionObserver(e=>{e.forEach(x=>{if(x.isIntersecting){x.target.classList.add('visible');obs.unobserve(x.target);}});},{threshold:.1});

  async function render(){
    const params=new URLSearchParams(window.location.search);
    const svcId=params.get('id');
    if(!svcId){ document.getElementById('page-loader').classList.add('gone'); return; }

    const [svc, allSvcs, contacts] = await Promise.all([
      getServiceById(svcId), getLiveServices(), getContacts()
    ]);

    if(!svc){ document.getElementById('page-loader').classList.add('gone'); return; }

    const l = svc.langs?.[lang] || svc.langs?.en || {};
    document.title = `${l.name||'Service'} — Tbil Inn`;

    // Hero
    document.getElementById('hero-img').src    = svc.cover||'';
    document.getElementById('svc-name').textContent  = l.name||'';
    document.getElementById('svc-short').textContent = l.short||'';

    // Content
    document.getElementById('svc-title-2').textContent  = l.name||'';
    document.getElementById('svc-short-2').textContent  = l.short||'';
    document.getElementById('svc-desc').textContent     = l.description||'';
    document.getElementById('svc-sidebar-name').textContent = l.name||'';

    // Details
    document.getElementById('svc-price').textContent    = svc.details?.price||'—';
    document.getElementById('svc-duration').textContent = svc.details?.duration||'—';
    document.getElementById('svc-avail').textContent    = svc.details?.availability||'—';
    document.getElementById('svc-cat').textContent      = svc.details?.category||'—';
    document.getElementById('mobile-avail').textContent = svc.details?.availability||'';

    // Book buttons
    const bookEmail = svc.details?.booking || contacts?.email || 'hello@tbilinn.ge';
    const subject = encodeURIComponent(`${l.name||'Service'} Inquiry`);
    document.getElementById('btn-book').onclick = () => window.location = `mailto:${bookEmail}?subject=${subject}`;
    document.getElementById('cta-btn').onclick  = () => window.location = `mailto:${bookEmail}?subject=${subject}`;

    // Gallery strip
    if(svc.photos?.length){
      document.getElementById('gallery-strip').innerHTML = svc.photos.map(url=>`
        <div class="gallery-item"><img src="${url}" alt="" loading="lazy"></div>`).join('');
    } else {
      document.getElementById('gallery-strip').style.display='none';
    }

    // Includes
    if(l.includes){
      const items = l.includes.split('\n').filter(Boolean);
      if(items.length){
        document.getElementById('includes-list').innerHTML = items.map(item=>`<li>${item}</li>`).join('');
      } else {
        document.getElementById('includes-section').style.display='none';
      }
    } else {
      document.getElementById('includes-section').style.display='none';
    }

    // Other services
    const others = allSvcs.filter(s=>s.id!==svcId).slice(0,3);
    if(others.length){
      document.getElementById('other-services-grid').innerHTML = others.map(s=>{
        const sl = s.langs?.[lang]||s.langs?.en||{};
        return `<a href="service.html?id=${s.id}" class="service-card fade-in">
          <div class="service-card-img"><img src="${s.cover||''}" alt="${sl.name||''}" loading="lazy"></div>
          <div class="service-card-body">
            <span class="service-card-cat">${s.details?.category||''}</span>
            <h3 class="service-card-title">${sl.name||''}</h3>
            <p class="service-card-desc">${sl.short||''}</p>
            <span class="service-card-link">${ui.explore}</span>
          </div>
        </a>`;
      }).join('');
    }

    document.querySelectorAll('.fade-in').forEach(el=>obs.observe(el));
    document.getElementById('page-loader').classList.add('gone');
  }

  render();
  </script>
</body>
</html>
